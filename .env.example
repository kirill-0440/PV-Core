# Copy to .env.local or export values in your shell.
# Do not commit real API keys.

BITGN_API_KEY=
BITGN_ACCOUNT_ID=
BITGN_CHALLENGE=ecom
BITGN_BENCHMARK=bitgn/ecom1-prod

# Fill these after a real run.
BITGN_ECOM1_RUN_ID=
PVCORE_MAIN_MODEL=
PVCORE_PLANNER_MODEL=none
PVCORE_EVALUATOR_MODEL=none
PVCORE_RUNTIME_SETTINGS=temperature=0,max_tokens=8192,tool_policy=verified-only
